    { id: '211', name: "That's Not My Neighbor", image: '/images/thats-not-my-neighbor.png' },
    { id: '214', name: 'Bad Parenting', image: '/images/badparenting.png' },
    { id: '215', name: 'Dumb Ways to Die', image: '/images/dumbwaystodie.png' },
    { id: '216', name: 'Schoolboy Runaway', image: '/images/schoolboyrunaway.png' },
    { id: '217', name: 'Tattletail', image: '/images/tattletail.png' }
  ];

  // Store games globally
  window.nebulaGames = allGames.filter(g => g.id !== '169').map(g => ({
    name: g.name,
    image: g.image,
    url: `/_/${g.id}/`
  }));

  // Create game card HTML
  function createGameCard(game) {
    const escapedName = game.name.replace(/'/g, "\\'");
    return `
      <a class="game-card" onclick="playGame('${game.id}', '${escapedName}', '${game.image}')">
        <div class="game-card-image">
          <img src="${game.image}" alt="${game.name}" loading="lazy">
          <div class="game-card-play">
            <div class="game-card-play-btn"><i class="fas fa-play"></i> Play</div>
          </div>
        </div>
        <div class="game-card-info">
          <div class="game-card-title">${game.name}</div>
        </div>
      </a>
    `;
  }

  // Play game function
  function playGame(id, name, image) {
    addToRecentlyPlayed(`/_/${id}/`, name, image);
    window.location.href = `_/${id}/`;
  }

  // Render all games
  function renderGames() {
    const container = document.getElementById('games');
    container.innerHTML = allGames.map(createGameCard).join('');
  }

  // Search functionality
  const searchInput = document.getElementById('search');
  const searchResults = document.getElementById('search-results');

  searchInput.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();
    
    if (query.length < 2) {
      searchResults.classList.remove('active');
      return;
    }
    
    const matches = allGames.filter(g => 
      g.name.toLowerCase().includes(query)
    ).slice(0, 8);
    
    if (matches.length === 0) {
      searchResults.classList.remove('active');
      return;
    }
    
    searchResults.innerHTML = matches.map(game => `
      <div class="search-result-item" onclick="playGame('${game.id}', '${game.name}', '${game.image}')">
        <img src="${game.image}" alt="${game.name}">
        <span>${game.name}</span>
      </div>
    `).join('');
    
    searchResults.classList.add('active');
  });

  document.addEventListener('click', (e) => {
    if (!e.target.closest('.nav-search')) {
      searchResults.classList.remove('active');
    }
  });

  // Recently played functions
  function getRecentlyPlayed() {
    const recent = localStorage.getItem('recentlyPlayed');
    return recent ? JSON.parse(recent) : [];
  }

  function addToRecentlyPlayed(url, name, image) {
    if (url.includes('_/169/')) return;
    let recent = getRecentlyPlayed();
    recent = recent.filter(g => g.url !== url);
    recent.unshift({ url, name, image });
    recent = recent.slice(0, 5);
    localStorage.setItem('recentlyPlayed', JSON.stringify(recent));
  }

  function displayRecentlyPlayed() {
    const container = document.getElementById('recently-played');
    const section = document.getElementById('recently-played-section');
    const recent = getRecentlyPlayed();
    
    if (recent.length === 0) {
      section.style.display = 'none';
      return;
    }
    
    section.style.display = 'block';
    container.innerHTML = recent.map(game => `
      <a class="game-card" onclick="window.location.href='${game.url}'">
        <div class="game-card-image">
          <img src="${game.image}" alt="${game.name}">
          <div class="game-card-play">
            <div class="game-card-play-btn"><i class="fas fa-play"></i> Play</div>
          </div>
        </div>
        <div class="game-card-info">
          <div class="game-card-title">${game.name}</div>
        </div>
      </a>
    `).join('');
  }

  // Random games functions
  function getRecentlyShownRandom() {
    const recent = localStorage.getItem('recentlyShownRandom');
    return recent ? JSON.parse(recent) : [];
  }

  function updateRecentlyShownRandom(urls) {
    let recent = getRecentlyShownRandom();
    recent.push(...urls);
    recent = recent.slice(-50);
    localStorage.setItem('recentlyShownRandom', JSON.stringify(recent));
  }

  function getRandomGames(count) {
    const recentlyShown = getRecentlyShownRandom();
    let available = allGames.filter(g => g.id !== '169' && !recentlyShown.includes(`/_/${g.id}/`));
    
    if (available.length < count) {
      available = allGames.filter(g => g.id !== '169');
      localStorage.removeItem('recentlyShownRandom');
    }
    
    for (let i = available.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [available[i], available[j]] = [available[j], available[i]];
    }
    
    const selected = available.slice(0, count);
    updateRecentlyShownRandom(selected.map(g => `/_/${g.id}/`));
    return selected;
  }

  function displayRandomGames() {
    const container = document.getElementById('random-games');
    const randomGames = getRandomGames(5);
    
    container.innerHTML = randomGames.map(game => `
      <a class="game-card" onclick="playGame('${game.id}', '${game.name}', '${game.image}')">
        <div class="game-card-image">
          <img src="${game.image}" alt="${game.name}">
          <div class="game-card-play">
            <div class="game-card-play-btn"><i class="fas fa-play"></i> Play</div>
          </div>
        </div>
        <div class="game-card-info">
          <div class="game-card-title">${game.name}</div>
        </div>
      </a>
    `).join('');
  }

  // Theme Toggle
  const themeToggle = document.getElementById('theme-toggle');
  const sunIcon = themeToggle.querySelector('.fa-sun');
  const moonIcon = themeToggle.querySelector('.fa-moon');
  
  function setTheme(theme) {
    if (theme === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      sunIcon.style.display = 'none';
      moonIcon.style.display = 'inline';
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.removeAttribute('data-theme');
      sunIcon.style.display = 'inline';
      moonIcon.style.display = 'none';
      localStorage.setItem('theme', 'light');
    }
  }
  
  // Check saved theme preference (default to dark)
  const savedTheme = localStorage.getItem('theme');
  setTheme(savedTheme || 'dark');
  
  themeToggle.addEventListener('click', () => {
    const currentTheme = document.documentElement.getAttribute('data-theme');
    setTheme(currentTheme === 'dark' ? 'light' : 'dark');
  });

  function createParticles() {
    const container = document.getElementById('hero-particles');
    if (!container) return;
    for (let i = 0; i < 20; i++) {
      const p = document.createElement('div');
      p.className = 'hero-particle';
      p.style.left = Math.random() * 100 + '%';
      p.style.bottom = '-4px';
      p.style.animationDuration = (4 + Math.random() * 6) + 's';
      p.style.animationDelay = (Math.random() * 5) + 's';
      p.style.width = p.style.height = (2 + Math.random() * 2) + 'px';
      container.appendChild(p);
    }
  }

  document.getElementById('shuffle-btn').addEventListener('click', () => {
    const btn = document.getElementById('shuffle-btn');
    const grid = document.getElementById('random-games');
    btn.querySelector('i').style.transform = 'rotate(360deg)';
    setTimeout(() => btn.querySelector('i').style.transform = '', 400);
    grid.style.opacity = '0';
    grid.style.transform = 'translateY(10px)';
    setTimeout(() => {
      localStorage.removeItem('recentlyShownRandom');
      displayRandomGames();
      grid.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
      grid.style.opacity = '1';
      grid.style.transform = 'translateY(0)';
      setTimeout(() => { grid.style.transition = ''; }, 400);
    }, 250);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
      e.preventDefault();
      document.getElementById('search').focus();
    }
    if (e.key === 'Escape') {
      document.getElementById('search').blur();
    }
  });

  const backToTop = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      backToTop.classList.add('visible');
    } else {
      backToTop.classList.remove('visible');
    }
    const nav = document.querySelector('.main-nav');
    if (window.scrollY > 20) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  });
  backToTop.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  function initScrollReveal() {
    const sections = document.querySelectorAll('.reveal-section');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05, rootMargin: '0px 0px -20px 0px' });
    sections.forEach((el, i) => {
      el.style.transitionDelay = (i * 0.1) + 's';
      observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    renderGames();
    displayRecentlyPlayed();
    displayRandomGames();
    createParticles();
    initScrollReveal();
  });

  document.addEventListener('contextmenu', e => e.preventDefault());
  </script>
<script src="/mobile-ad.js"></script>
</body>
</html>
<script>
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('search').focus();
    }
    if (e.key === 'Escape') {
      document.getElementById('search').blur();
      document.getElementById('search-results').classList.remove('active');
    }
  });
</script>
